   "source": [
    "def findthedublicates(list):\n",
    "    s=[]\n",
    "    dub=[]\n",
    "    for i in list:\n",
    "        if i in s and i not in dub:\n",
    "            dub.append(i)\n",
    "        else:\n",
    "            s.append(i)\n",
    "\n",
    "    return dub\n",
    "\n",
    "l=[1,2,2,55,4,4,58,65,65]\n",
    "res=findthedublicates(l)\n",
    "\n",
    "print(\"dublicate are =\", res)"
   ]
